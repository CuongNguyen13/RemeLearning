# Set to false to skip Kafka entirely at startup (REST endpoints /api/v1/upload,
# /api/v1/transcribe, /api/v1/analyze still work without Kafka running).
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=ai-service

REDIS_HOST=localhost
REDIS_PORT=6379

S3_REGION=ap-southeast-1
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

WHISPER_MODEL_SIZE=small
DEVICE=cpu
HF_TOKEN=

# Mistake-ranking analyzer for the learning.gap.analysis.requested path:
# rule-based (legacy occurrence x Ebbinghaus) | scoring-engine (Java-consistent composite formula).
ANALYSIS_SCORER=rule-based

# On-device Supertonic TTS (app/tts/), used by english-service dictation AI-practice audio.
TTS_ENABLED=true
TTS_DEFAULT_VOICE=F1
TTS_DEFAULT_LANG=en

# Set to true to caption sampled video frames (Gemini vision) and merge them into the
# transcript's segments, so recurring-vocabulary analysis can also draw on on-screen
# text/objects, not just spoken words.
VISION_ENABLED=false
VISION_FRAME_INTERVAL_SECONDS=10.0
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash

API_HOST=0.0.0.0
API_PORT=8000
